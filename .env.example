# ── Base de datos ──────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/rentia_db

# ── Servidor ───────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET=cambia_esto_por_un_secreto_seguro_de_al_menos_32_chars

# ── CORS ───────────────────────────────────────────────────
# URL(s) del frontend separadas por coma
CORS_ORIGIN=https://tu-frontend.com

# ── SMTP (recordatorios y emails de bienvenida) ────────────
SMTP_HOST=smtp.ejemplo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@tudominio.com
SMTP_PASS=tu_contraseña_smtp
SMTP_FROM=Rentia <notificaciones@tudominio.com>

# ── Recordatorios ──────────────────────────────────────────
# Días antes del vencimiento para enviar recordatorio (default: 3)
REMINDER_DAYS_BEFORE=3
