# ===== BASE DE DATOS =====
DATABASE_URL=postgresql://user:password@localhost:5432/saa

# ===== AUTENTICACIÓN =====
# Genera con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-cadena-aleatoria-de-al-menos-32-caracteres
JWT_EXPIRES_IN=7d

# ===== SERVIDOR =====
PORT=4000
NODE_ENV=production

# ===== CORS =====
# Lista separada por comas de orígenes permitidos del frontend
CORS_ORIGIN=http://localhost:5173,https://tu-frontend.onrender.com

# ===== CORREO (opcional, para notificaciones) =====
# Si no completas estos datos, las notificaciones quedan deshabilitadas
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-correo@gmail.com
SMTP_PASS=clave-de-aplicacion
SMTP_FROM="SAA <noreply@tu-dominio.com>"

# ===== RECORDATORIOS =====
# Días antes del vencimiento para enviar recordatorios
REMINDER_DAYS_BEFORE=3
